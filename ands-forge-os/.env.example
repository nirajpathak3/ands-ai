# ANDS Forge OS — configuration (env-driven, safe offline defaults).
# Copy this file to `.env` (same folder) and flip flags to move from offline-deterministic
# to real providers. The app auto-loads `.env` on startup; real OS env vars override it.
# `.env` is gitignored — your keys never get committed. The kernel runs end-to-end with
# NONE of these set.

# --- Service ---------------------------------------------------------------
FORGE_ENV=development
HOST=0.0.0.0
PORT=8099

# --- Execution mode --------------------------------------------------------
# offline = skill-pack agents echo a deterministic seed via the deterministic
#           provider (no keys, $0, reproducible) — the default.
# live    = the same agents call real providers, validate structured output, and
#           reprompt on invalid JSON; they fall back to the seed if a model never
#           complies (so a run never hard-fails, even with no keys configured).
FORGE_MODE=offline

# --- AI Gateway / LLM egress ----------------------------------------------
# Real providers are used ONLY in live mode (FORGE_MODE=live) and only when their key
# is set; offline stays deterministic ($0) even if keys are present. Deterministic is
# always the final fallback.
#
# Recommended free/cloud backend: Gemini (Google AI Studio key, free tier). No PC needs
# to stay on, no extra subscription. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
LLM_TIMEOUT_S=30
LLM_CACHE_ENABLED=true
LLM_CACHE_SIMILARITY=0.92

# --- Model tiers (assign which model does which task/stage) ----------------
# Swap these as new models ship — one-line change, no code. The "strong" tier serves
# reasoning-heavy work (the Critic/Red-team judge + any stage listed in STRONG_STAGES);
# the "cheap" tier serves high-volume drafting. A blueprint stage/artifact `model:` pins
# a specific model and overrides the tiers.
FORGE_MODEL_STRONG=gemini-2.5-pro
FORGE_MODEL_CHEAP=gemini-2.5-flash
# Comma-separated stage keys that use the strong tier (e.g. the technical/architecture stage).
FORGE_STRONG_STAGES=technical

# --- Fake live provider (demo/test the LIVE path with NO API keys) ---------
# Only active when FORGE_MODE=live. A scripted provider that behaves like a real
# model (generates structured JSON, simulated cost) so the live path is visible
# without keys. FLAKY injects one invalid response per artifact to show the
# bounded reprompt. See: python scripts/demo_live_fake.py
FORGE_FAKE_LIVE=false
FORGE_FAKE_LIVE_FLAKY=false

# --- Scheduler / budget governor ------------------------------------------
FORGE_MAX_CONCURRENCY=4
FORGE_BUDGET_USD=5.0
FORGE_BUDGET_WALL_SECONDS=600

# --- Gates (materiality dial) ---------------------------------------------
# Per-gate mode is set in the blueprint/roster; this is the global default when
# a gate omits one: always-human | auto-if-eval | auto
FORGE_DEFAULT_GATE_MODE=auto-if-eval
FORGE_EVAL_QUALITY_BAR=0.75
# Bounded reprompts when a live model returns invalid structured output (ADR-010).
# Lower this (e.g. 1) to spend fewer tokens per artifact on free tiers.
FORGE_ANALYSIS_MAX_RETRIES=2
# LLM-as-judge for the Critic/Red-team review (live mode). Set to false to use only the
# deterministic heuristic eval — this ~halves live LLM calls per run (no judge call per
# artifact). Quality gates still run; just without a model second opinion. No-op offline.
FORGE_LLM_JUDGE=true

# --- Workspace -------------------------------------------------------------
# Where Forge writes run state and scaffolded product repos.
FORGE_WORKSPACE=var

# --- Observability ---------------------------------------------------------
LOG_JSON=false
OTEL_ENABLED=false
