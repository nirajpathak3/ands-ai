# ── Agent Runtime configuration ───────────────────────────────────────────────
# Copy to .env and fill in. Never commit real secrets (.env is git-ignored).

# Service
SERVICE_NAME=agent-runtime
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8088

# AI Gateway (single LLM egress; the runtime never calls providers directly)
GATEWAY_BASE_URL=http://localhost:3000

# Governance thresholds (defaults from PRODUCT_VISION.md)
GOVERNANCE_AUTO_THRESHOLD=0.90
GOVERNANCE_SUGGEST_THRESHOLD=0.60

# Data stores (used from Day 5+; leave blank for the walking skeleton)
DATABASE_URL=
REDIS_URL=

# NOTE: LLM provider keys (OPENAI_API_KEY / ANTHROPIC_API_KEY) live in the
# GATEWAY service, not here. The runtime stays provider-agnostic on purpose.
