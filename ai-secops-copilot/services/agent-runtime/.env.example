# ── Agent Runtime configuration ───────────────────────────────────────────────
# Copy to .env and fill in. Never commit real secrets (.env is git-ignored).

# Service
SERVICE_NAME=agent-runtime
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8088

# AI Gateway (single LLM egress; the runtime never calls providers directly)
GATEWAY_BASE_URL=http://localhost:3000

# LLM egress (Day 11). Offline default = deterministic provider (no keys, free,
# reproducible). Set a key to activate a real provider; deterministic stays as the
# final fallback so a provider outage degrades instead of failing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
LLM_TIMEOUT_S=30
# Semantic cache: reuse completions for near-identical prompts to cut cost/latency.
LLM_CACHE_ENABLED=true
LLM_CACHE_SIMILARITY=0.92

# Observability (Day 12). In-process tracing + structured logs are always on; OTel export
# activates only when OTEL_ENABLED=true and the OpenTelemetry SDK is installed.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_JSON=true
# Alert thresholds: a rule fires when the live value exceeds the threshold.
ALERT_ESCALATION_RATE=0.30
ALERT_FALLBACK_RATE=0.20
ALERT_P95_LATENCY_MS=1500
ALERT_COST_PER_REQUEST_USD=0.01
ALERT_APPROVAL_BACKLOG=25

# Governance thresholds (defaults from PRODUCT_VISION.md)
GOVERNANCE_AUTO_THRESHOLD=0.90
GOVERNANCE_SUGGEST_THRESHOLD=0.60
# Bounded re-prompts on invalid structured output (ADR-010)
ANALYSIS_MAX_RETRIES=2

# RAG knowledge layer (ADR-001). Offline lexical retriever by default; set
# DATABASE_URL to enable the pgvector backend (ADR-002) once embeddings are wired.
RAG_ENABLED=true
RAG_TOP_K=3

# Ticketing provider: mock (default, no creds) | servicenow (mock) | jira (real)
TICKET_PROVIDER=mock
# Jira Cloud (only needed when TICKET_PROVIDER=jira). Use a free Atlassian dev site.
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Data stores. Persistence backend (Day 10) is derived from DATABASE_URL:
#   (blank)                         -> in-memory (offline default)
#   sqlite:///var/secops.db         -> durable SQLite (local/CI durability)
#   postgresql://user:pw@host/db    -> Postgres (production; infra/postgres/state.sql)
DATABASE_URL=
REDIS_URL=

# NOTE: LLM provider keys (OPENAI_API_KEY / ANTHROPIC_API_KEY) live in the
# GATEWAY service, not here. The runtime stays provider-agnostic on purpose.
