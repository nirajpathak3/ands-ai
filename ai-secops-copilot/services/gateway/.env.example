# ── Gateway / Control Plane configuration ─────────────────────────────────────
# Copy to .env and fill in. Never commit real secrets (.env is git-ignored).

NODE_ENV=development
PORT=3000

# Python agent runtime (LangGraph)
AGENT_RUNTIME_URL=http://localhost:8088

# AI Gateway providers — OpenAI primary, Claude fallback (ADR-006).
# Leave blank to run the scaffold without LLM calls; /health reports presence only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Semantic cache (Redis-backed; wired Day 12)
GATEWAY_CACHE_ENABLED=false
