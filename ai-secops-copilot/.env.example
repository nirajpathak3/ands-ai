# ── Root / shared local-dev configuration ─────────────────────────────────────
# Copy to .env (git-ignored). Per-service env lives in services/*/.env.example.

# Local infrastructure (matches docker-compose.yml)
POSTGRES_USER=secops
POSTGRES_PASSWORD=secops
POSTGRES_DB=secops

# Connection strings the services consume (Day 5+ / Day 12+)
DATABASE_URL=postgresql://secops:secops@localhost:5432/secops
REDIS_URL=redis://localhost:6379/0
